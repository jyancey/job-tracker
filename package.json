{
  "name": "job-tracker",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/require-pnpm.mjs",
    "pre-build": "tsx scripts/withColor.ts tsx scripts/generate-version.ts",
    "dev": "pnpm run pre-build && tsx scripts/withColor.ts next dev -H 127.0.0.1 -p 4173",
    "build": "pnpm run pre-build && tsx scripts/withColor.ts next build",
    "start": "tsx scripts/withColor.ts next start -H 127.0.0.1 -p 3100",
    "lint": "tsx scripts/withColor.ts tsx ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "tsx scripts/withColor.ts tsx ./node_modules/eslint/bin/eslint.js . --fix",
    "preview": "tsx scripts/withColor.ts next start -H 127.0.0.1 -p 3100",
    "serve": "tsx scripts/withColor.ts next start -H 127.0.0.1 -p 3100",
    "test": "tsx scripts/withColor.ts vitest",
    "pretest:run": "tsx scripts/withColor.ts tsx scripts/generate-version.ts",
    "test:run": "tsx scripts/withColor.ts vitest run",
    "pretest:coverage": "tsx scripts/withColor.ts tsx scripts/generate-version.ts",
    "test:coverage": "tsx scripts/withColor.ts vitest run --coverage",
    "test:e2e": "tsx scripts/withColor.ts playwright test",
    "test:e2e:ui": "tsx scripts/withColor.ts playwright test --ui"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "next": "^16.1.7",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
