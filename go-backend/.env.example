# Server port (default: 3101)
PORT=3101

# Path to SQLite database file
# Default: ../backend/data/job-tracker.sqlite (shared with TypeScript backend)
JOB_TRACKER_DB_PATH=../backend/data/job-tracker.sqlite

# Comma-separated CORS origins allowed to access the API
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
